# WoClaw Environment Variables
# Copy this file to .env and fill in your values

# Authentication token for the Hub
# ⚠️ IMPORTANT: Change this to a secure random token in production!
# The Hub will reject requests without this token.
AUTH_TOKEN=change-me-in-production

# Hub host (default: 0.0.0.0)
HOST=0.0.0.0

# WebSocket port (default: 8082)
PORT=8082

# REST API port (default: 8083)
REST_PORT=8083

# Data directory for persistent storage (default: /data)
DATA_DIR=/data
